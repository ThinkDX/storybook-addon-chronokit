{
  "name": "storybook-addon-chronokit",
  "version": "1.0.0",
  "description": "Mock time in your Storybook stories — freeze the clock or fast-forward it with a single decorator.",
  "keywords": [
    "storybook",
    "storybook-addons",
    "addon",
    "date",
    "time",
    "clock",
    "mock",
    "testing"
  ],
  "homepage": "https://thinkdx.github.io/storybook-addon-chronokit/",
  "bugs": "https://github.com/ThinkDX/storybook-addon-chronokit/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ThinkDX/storybook-addon-chronokit.git"
  },
  "license": "MIT",
  "author": "Nick Ferraro",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json && node scripts/make-cts-types.mjs",
    "prepublishOnly": "npm run build",
    "test": "vitest",
    "test:run": "vitest run",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.node.json --noEmit"
  },
  "peerDependencies": {
    "@storybook/react-vite": ">=9.0.0",
    "react": ">=18",
    "storybook": ">=9.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/node": "^25.0.9",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/browser-playwright": "^4.0.17",
    "jsdom": "^27.4.0",
    "playwright": "^1.57.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "storybook": "^10.4.6",
    "tsup": "^8.3.5",
    "typescript": "~5.7.2",
    "vite": "^6.0.0",
    "vitest": "^4.0.17"
  }
}
