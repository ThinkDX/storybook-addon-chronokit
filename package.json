{
  "name": "storybook-addon-chronokit",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "test": "vitest",
    "test:run": "vitest run",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "lint": "biome lint .",
    "format": "biome format --write .",
